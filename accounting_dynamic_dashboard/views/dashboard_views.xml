<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Custom Kanban View (Primary Inherit) -->
        <record id="ag_custom_journal_dashboard_kanban_view" model="ir.ui.view">
            <field name="name">ag.account.journal.dashboard.kanban</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
            <field name="mode">primary</field>
            <field name="arch" type="xml">
                <!-- Add a custom class for CSS targeting (safe absolute positioning) -->
                <xpath expr="//kanban" position="attributes">
                    <attribute name="class" add="ag_custom_dashboard_kanban" separator=" "/>
                </xpath>
                
                <!-- Add shadow, rounding, and a light background to the main card container -->
                <xpath expr="//t[@t-name='card']/div" position="attributes">
                    <attribute name="class" add="shadow-sm rounded bg-light border-0" separator=" "/>
                </xpath>
                
                <xpath expr="//t[@t-name='JournalTop']//a" position="before">
                    <span t-if="journal_type == 'cash'" class="me-2 fs-3">💵</span>
                    <span t-if="journal_type == 'bank'" class="me-2 fs-3">🏦</span>
                    <span t-if="journal_type == 'sale'" class="me-2 fs-3">📈</span>
                    <span t-if="journal_type == 'purchase'" class="me-2 fs-3">🛒</span>
                </xpath>
                
                <!-- Make the top title larger and add some color to the text -->
                <xpath expr="//t[@t-name='JournalTop']//a" position="attributes">
                    <attribute name="class" add="text-primary fs-3" separator=" "/>
                </xpath>
            </field>
        </record>

        <!-- Custom Dashboard Action -->
        <record id="action_ag_custom_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard</field>
            <field name="res_model">account.journal</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="ag_custom_journal_dashboard_kanban_view"/>
            <field name="usage">menu</field>
            <field name="domain">[('custom_dashboard_visibility', '=', True), ('type', 'in', ['bank', 'cash', 'sale', 'purchase'])]</field>
            <field name="context">{'is_custom_dashboard': True}</field>
        </record>

        <!-- Custom Dashboard Menu (Sequence 1 to make it default in Accounting) -->
        <menuitem id="menu_ag_custom_dashboard" name="Dashboard" 
                  parent="at_accounting.menu_accounting" sequence="1" action="action_ag_custom_dashboard"/>

        <!-- Hide the default Odoo dashboard when this module is installed -->
        <!-- When uninstalled, Odoo will revert this change and unhide it automatically -->
        <menuitem id="account.menu_board_journal_1" active="False"/>

        <!-- Inherit Journal Form to add the dynamic option -->
        <record id="view_account_journal_form_inherit_ag" model="ir.ui.view">
            <field name="name">account.journal.form.inherit.ag</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='type']" position="after">
                    <field name="custom_dashboard_visibility"/>
                    <field name="sequence" />
                </xpath>
            </field>
        </record>

        <!-- Inherit the Journal Search View to add Bank and Cash filters -->
        <record id="view_account_journal_search_inherit_ag" model="ir.ui.view">
            <field name="name">account.journal.search.inherit.ag</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='dashboard']" position="before">
                    <filter name="bank" string="Bank" domain="[('type', '=', 'bank')]"/>
                    <filter name="cash" string="Cash" domain="[('type', '=', 'cash')]"/>
                    <separator/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
